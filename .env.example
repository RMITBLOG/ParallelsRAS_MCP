# Parallels RAS MCP Server Configuration
# These variables are typically set in your AI tool's MCP server config,
# not in a .env file. This file is for reference only.

RAS_HOST=ras-server.example.com
RAS_USERNAME=administrator
RAS_PASSWORD=your-password-here
RAS_PORT=20443
RAS_IGNORE_TLS=true

# Transport selection (optional — defaults to stdio).
# stdio: launched as a subprocess by the MCP client (local use only).
# http:  streamable-HTTP listener with bearer-token auth.
# MCP_TRANSPORT=stdio

# Required when MCP_TRANSPORT=http. Generate with: openssl rand -hex 32
# MCP_HTTP_BEARER_TOKEN=
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=3000
